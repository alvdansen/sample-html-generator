<!DOCTYPE html>
<html lang="en" data-theme="dark" data-density="comfortable" data-sync="independent">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Sample Grid — steps × prompts</title>
  {# css is a STATIC, trusted asset read from disk — emit it verbatim. Marking
     it `safe` is NOT a T-1-01 regression: it carries no user data, and inside a
     <style> block the browser does not decode HTML entities, so autoescaping the
     font-family quotes (&#34;) would actually BREAK the CSS. All dynamic
     prompt/filename interpolation below stays autoescaped. #}
  <style>
{{ css | safe }}
/* Build-injected (override the CSS defaults): detected AR (D-11), the CLI cell
   size (D-08), and the prompt-column count for the grid template. */
:root {
  --cell-ar: {{ cell_ar_css }};
  --cell-size: {{ cell_size_px }}px;
  --n-cols: {{ n_cols }};
}
  </style>
</head>
<body>
  {# Pinned theme/density toggle (D-03). Buttons carry data-set="key:value" +
     aria-pressed; grid.js (inlined near </body>) wires them and persists the
     choice to localStorage. With JS disabled the page keeps the dark/comfortable
     defaults baked into the CSS :root — the toggle simply does nothing. #}
  <div class="toggle-bar">
    <div class="toggle-group" role="group" aria-label="Theme">
      <span class="toggle-label">Theme</span>
      <button type="button" class="toggle-seg" data-set="theme:dark" aria-pressed="true">Dark</button>
      <button type="button" class="toggle-seg" data-set="theme:light" aria-pressed="false">Light</button>
    </div>
    <div class="toggle-group" role="group" aria-label="Density">
      <span class="toggle-label">Density</span>
      <button type="button" class="toggle-seg" data-set="density:comfortable" aria-pressed="true">Comfortable</button>
      <button type="button" class="toggle-seg" data-set="density:compact" aria-pressed="false">Compact</button>
    </div>
  </div>

  {# In-page seed-variance marker (D-09). Fired by build_grid's `seed_varies`,
     which ORs the per-coordinate multi-seed case AND the cross-cell seed
     confound — so this banner appears in the frozen HTML whenever seeds are
     mixed, keeping a terminal-free viewer honest. It carries no dynamic data,
     so there is nothing to escape here; any per-cell seed value below goes
     through autoescaped {{ }}. #}
  {% if seed_varies %}
  <div class="seed-variance" role="status" data-seed-variance>
    <span class="seed-variance__glyph" aria-hidden="true">⚠</span>
    <span class="seed-variance__text">Seeds vary across this grid — samples are not seed-locked.</span>
  </div>
  {% endif %}

  <div class="grid-scroll">
    <div class="grid" role="grid" aria-label="Model samples — steps as rows, prompts as columns">
      {# Corner cell + column (prompt) headers — sticky top #}
      <div class="corner" role="columnheader">step ╲ prompt</div>
      {% for prompt in prompts %}
      <div class="col-header" role="columnheader" title="{{ prompt }}" aria-label="{{ prompt }}">{{ prompt }}</div>
      {% endfor %}

      {# One dense row per step; row-header (left, sticky) then a cell per prompt #}
      {% for row in rows %}
      <div class="row-header" role="rowheader">{{ row.step }}</div>
      {% for item in row.cells %}
        {% if item.cell.state == POPULATED %}
          {% if item.cell.sample.media_type == "video" %}
      {# Video cell (MEDIA-01): a DIV, NOT an anchor — full-cell click is
         play/pause in Plan 02. The <video> carries NO eager src; the client
         attaches `data-src` on first play. The poster is the clip's OWN first
         frame via the `#t=0.001` media fragment (no ffmpeg / no generated
         thumbnails, D-10). `#t=0.001` is a STATIC in-template literal — never
         user data (Pitfall 5); every dynamic value stays autoescaped in {{ }}. #}
      <div class="cell cell--video{% if item.cell.ar_mismatch %} cell--mismatch{% endif %}"
           data-video data-src="{{ url(item.cell.sample) }}#t=0.001"
           role="button" tabindex="0" aria-pressed="false"
           aria-label="Play/pause — step {{ row.step }}, {{ item.prompt }}"
           title="step {{ row.step }} · {{ item.prompt }}">
        <video muted playsinline loop preload="none" aria-hidden="true"></video>
        <span class="cell__play" aria-hidden="true">▶</span>
        {# Pop-out (D-05): opens the RAW clip in a new tab using the CLEAN url
           (NO `#t=` poster fragment). rel=noopener noreferrer blocks reverse
           tabnabbing on the new tab (T-3-03), identical to the image anchor. #}
        <a class="cell__popout" href="{{ url(item.cell.sample) }}"
           target="_blank" rel="noopener noreferrer"
           aria-label="Open clip in new tab">⧉</a>
        {% if item.cell.has_alternates %}
        <span class="cell__alt-badge"
              title="Alternate seeds: {{ item.cell.alternate_seeds | join(', ') }}">alt</span>
        {% endif %}
      </div>
          {% else %}
      <a class="cell{% if item.cell.ar_mismatch %} cell--mismatch{% endif %}"
         href="{{ url(item.cell.sample) }}" target="_blank" rel="noopener noreferrer"
         title="step {{ row.step }} · {{ item.prompt }}">
        <img src="{{ url(item.cell.sample) }}" alt="step {{ row.step }}, {{ item.prompt }}"
             loading="lazy" decoding="async">
        {# Duplicate-seed alternate badge (D-10/D-09): only on cells where >1
           sample collided at this coordinate. Every seed value is interpolated
           through autoescaped {{ }} — never string-concatenated in Python. #}
        {% if item.cell.has_alternates %}
        <span class="cell__alt-badge"
              title="Alternate seeds: {{ item.cell.alternate_seeds | join(', ') }}">alt</span>
        {% endif %}
      </a>
          {% endif %}
        {% elif item.cell.state == BROKEN %}
      {# Broken: file present but won't decode — amber, solid, ⚠ (D-10). Not clickable. #}
      <div class="cell cell--broken"
           title="File found but couldn't be displayed — {{ item.cell.sample.path.name }}">
        <span class="cell__glyph" aria-hidden="true">⚠</span>
        <span class="cell__caption">Can't render</span>
      </div>
        {% else %}
      {# Missing: nothing was ever here — cold, dashed, em dash (D-09). Not clickable. #}
      <div class="cell cell--missing"
           title="No sample for step {{ row.step }} · {{ item.prompt }}">
        <span class="cell__glyph" aria-hidden="true">—</span>
        <span class="cell__caption">s{{ row.step }}·{{ item.prompt }}</span>
      </div>
        {% endif %}
      {% endfor %}
      {% endfor %}
    </div>
  </div>

  {# Inlined client JS (static, trusted) — marked `safe` for the same reason as
     css above: inside a <script> block the browser does not decode entities, so
     autoescaping its `>` / `"` would break the script. It is vanilla and
     file://-safe — NO EventSource / no server wiring (live=False in P1). #}
  <script>
{{ js | safe }}
  </script>
</body>
</html>
